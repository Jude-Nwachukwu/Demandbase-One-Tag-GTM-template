___SANDBOXED_JS_FOR_WEB_TEMPLATE___

// ─────────────────────────────────────────────────────────────────────────────
// Demandbase Tag — GTM Custom Tag Template
// Supports: Initial Page Load (base script injection) and SPA URL Change (IpApi)
// ─────────────────────────────────────────────────────────────────────────────

const injectScript = require('injectScript');
const callInWindow = require('callInWindow');
const logToConsole = require('logToConsole');
const queryPermission = require('queryPermission');

// ─── Determine which tag mode is configured ───────────────────────────────────
const tagType = data.tagType;

// ─────────────────────────────────────────────────────────────────────────────
// MODE 1: Initial Page Load — inject the Demandbase base library script
// ─────────────────────────────────────────────────────────────────────────────
if (tagType === 'initialLoad') {

  // Validate that a Tracking ID has been provided
  const trackingId = data.trackingId;

  if (!trackingId) {
    logToConsole('Demandbase Tag: Tracking ID is missing. Tag will not fire.');
    data.gtmOnFailure();
    return;
  }

  // Build the Demandbase script URL using the provided Tracking ID
  const scriptUrl = 'https://tag.demandbase.com/' + trackingId + '.min.js';

  // Confirm inject_script permission covers this URL before proceeding
  if (!queryPermission('inject_script', scriptUrl)) {
    logToConsole('Demandbase Tag: inject_script permission not granted for URL: ' + scriptUrl);
    data.gtmOnFailure();
    return;
  }

  // Inject the Demandbase script asynchronously
  // cacheToken ensures the script is only injected once per page,
  // even if this tag fires multiple times in the same session.
  injectScript(
    scriptUrl,
    data.gtmOnSuccess,  // Called when script loads successfully
    data.gtmOnFailure,  // Called if script fails to load
    'demandbase_js_lib' // cacheToken — prevents duplicate script injection
  );

// ─────────────────────────────────────────────────────────────────────────────
// MODE 2: SPA URL Change — call Demandbase.IpApi.get() on route change
// ─────────────────────────────────────────────────────────────────────────────
} else if (tagType === 'spaFire') {

  // Attempt to call Demandbase.IpApi.get() via the window object.
  // This relies on the base Demandbase script already being loaded
  // by the Initial Page Load tag on first render.

  if (!queryPermission('access_globals', 'execute', 'Demandbase.IpApi.get')) {
    logToConsole('Demandbase Tag: access_globals execute permission not granted for Demandbase.IpApi.get');
    data.gtmOnFailure();
    return;
  }

  callInWindow('Demandbase.IpApi.get');
  data.gtmOnSuccess();

// ─────────────────────────────────────────────────────────────────────────────
// Fallback — unrecognised tag type
// ─────────────────────────────────────────────────────────────────────────────
} else {
  logToConsole('Demandbase Tag: Unknown tag type "' + tagType + '". Tag will not fire.');
  data.gtmOnFailure();
}


